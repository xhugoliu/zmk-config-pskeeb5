#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/mouse.h>
#include <dt-bindings/zmk/bt.h>
#include <behaviors/mouse_setting.dtsi>
#include <dt-bindings/zmk/mouse_settings.h>

// 小红点灵敏度快捷键，放在设备控制层中直接调用
#define U_MSS_TP_S_I &mms MS_TP_SENSITIVITY_INCR
#define U_MSS_TP_S_D &mms MS_TP_SENSITIVITY_DECR

#define ENCODER_SCROLL_STEP 2000

// 默认层旋钮行为：
// 左旋钮顺时针音量加、逆时针音量减
// 右旋钮顺时针上滚动、逆时针下滚动
#define BASE_LEFT_ENCODER &inc_dec_kp C_VOL_DN C_VOL_UP
#define BASE_RIGHT_ENCODER &inc_dec_msc MOVE_Y(-ENCODER_SCROLL_STEP) MOVE_Y(ENCODER_SCROLL_STEP)

// 第 2 层旋钮行为：
// 右旋钮顺时针右箭头、逆时针左箭头
#define NAV_RIGHT_ENCODER &inc_dec_kp LEFT RIGHT

// 第 3 层旋钮行为：
// 左旋钮顺时针亮度加、逆时针亮度减
#define SYMBOL_LEFT_ENCODER &inc_dec_kp C_BRI_DN C_BRI_UP

/ {
    behaviors {
        // 轻击输出普通按键，按住输出修饰键
        ht: hold_tap {
            display-name = "Hold Tap";
            label = "hold_tap";
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "balanced";
            tapping-term-ms = <220>;
            quick-tap-ms = <200>;
            bindings = <&kp>, <&kp>;
        };

        // 轻击输出按键，按住临时进入目标层
        lt: layer_tap {
            display-name = "Layer Tap";
            compatible = "zmk,behavior-hold-tap";
            label = "LAYER_TAP";
            #binding-cells = <2>;
            tapping-term-ms = <200>;
            quick-tap-ms = <200>;
            bindings = <&mo>, <&kp>;
        };

        // 编码器滚轮行为模板，使用时传入两个滚轮方向参数
        inc_dec_msc: sensor_rotate_msc {
            compatible = "zmk,behavior-sensor-rotate-var";
            #sensor-binding-cells = <2>;
            bindings = <&msc>, <&msc>;
            tap-ms = <20>;
        };
    };

    combos {
        compatible = "zmk,combos";

        // W + E 并击输出 Tab
        combo_tab {
            timeout-ms = <50>;
            key-positions = <1 2>;
            bindings = <&kp TAB>;
        };

        // E + R 并击输出反引号
        combo_grave {
            timeout-ms = <50>;
            key-positions = <2 3>;
            bindings = <&kp GRAVE>;
        };

        // U + I 并击输出 F20
        combo_f20 {
            timeout-ms = <50>;
            key-positions = <6 7>;
            bindings = <&kp F20>;
        };

        // 左右鼠标键并击输出鼠标中键
        middle_click {
            timeout-ms = <50>;
            key-positions = <33 34>;
            bindings = <&mkp MCLK>;
        };
    };

    conditional_layers {
        compatible = "zmk,conditional-layers";

        // 第 2 层和第 3 层同时激活时，自动进入第 5 层设备控制层
        device_layer {
            if-layers = <2 3>;
            then-layer = <5>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        // 第 0 层：默认输入层
        // - 主键区是标准 QWERTY
        // - S D F G / H J K L 为 home-row mods
        // - Esc / Space / Enter / Backspace 按住分别进入第 1 / 2 / 3 / 4 层
        // - 左旋钮按下静音，右旋钮按下 Print Screen
        default_layer {
            bindings = <
        // 第一排：QWERTY 顶排
            &kp Q          &kp W          &kp E          &kp R          &kp T             &kp Y          &kp U           &kp I           &kp O         &kp P
        // 第二排：主字母 + home-row mods
            &kp A          &ht LGUI S     &ht LSHFT D    &ht LCTRL F    &ht LALT G        &ht RALT H     &ht RCTRL J     &ht RSHFT K     &ht RGUI L    &kp SEMI
        // 第三排：标准底排
            &kp Z          &kp X          &kp C          &kp V          &kp B             &kp N          &kp M           &kp COMMA       &kp DOT       &kp FSLH
        // 底行：左旋钮按下、Esc/Space 层切换、鼠标左右键、Enter/Backspace 层切换、右旋钮按下
                        &kp C_MUTE    &lt 1 ESC     &lt 2 SPACE   &mkp RCLK      &mkp LCLK       &lt 3 ENTER   &lt 4 BSPC      &kp PSCRN
            >;
            sensor-bindings = <BASE_LEFT_ENCODER BASE_RIGHT_ENCODER>;
        };

        // 第 1 层：小数字键盘层
        // - 右手是小键盘主体
        // - 左手补一组常用左修饰键
        // - 旋钮旋转显式保持第 0 层行为，按下继续走按键透传
        numpad_layer {
            bindings = <
        // 第一排：右手数字区上排
            &none          &none          &none         &none          &none             &kp KP_PLUS    &kp KP_N7       &kp KP_N8       &kp KP_N9     &kp KP_MULTIPLY
        // 第二排：左修饰键 + 小键盘中排
            &none          &kp LGUI       &kp LSHFT     &kp LCTRL      &kp LALT          &kp KP_MINUS   &kp KP_N4       &kp KP_N5       &kp KP_N6     &kp KP_DIVIDE
        // 第三排：小键盘下排
            &none          &none          &none         &none          &none             &kp KP_NUMLOCK &kp KP_N1       &kp KP_N2       &kp KP_N3     &kp KP_EQUAL
        // 底行：旋钮按下保持透传，右侧补 Kp 0 和 Kp .
                        &trans        &trans         &trans        &trans          &trans            &kp KP_N0     &kp KP_DOT      &trans
            >;
            sensor-bindings = <BASE_LEFT_ENCODER BASE_RIGHT_ENCODER>;
        };

        // 第 2 层：方向导航层
        // - 右手中区是 Home / PgDn / PgUp / End 和方向键
        // - 最下一排右手改成滚动方向
        // - 左旋钮旋转保持第 0 层音量，右旋钮旋转改成左右方向键，按下继续透传
        navigation_layer {
            bindings = <
        // 第一排：导航键
            &none          &none          &none         &none          &none             &kp HOME       &kp PG_DN       &kp PG_UP       &kp END       &none
        // 第二排：左修饰键 + 方向键
            &none          &kp LGUI       &kp LSHFT     &kp LCTRL      &kp LALT          &kp LEFT       &kp DOWN        &kp UP          &kp RIGHT     &none
        // 第三排：滚动方向
            &none          &none          &none         &none          &none             &msc SCRL_LEFT &msc SCRL_DOWN  &msc SCRL_UP    &msc SCRL_RIGHT &none
        // 底行：旋钮按下保持透传，其余大多透传，仅最右侧拇指键改成 Delete
                        &trans        &trans         &trans        &trans          &trans            &trans        &kp DEL         &trans
            >;
            sensor-bindings = <BASE_LEFT_ENCODER NAV_RIGHT_ENCODER>;
        };

        // 第 3 层：数字符号层
        // - 第一排放 1-0
        // - 第二排放左右修饰键
        // - 第三排集中常用符号
        // - 左旋钮按下透传、旋转改成亮度调节右旋钮旋转显式保持第 0 层，按下透传
        number_symbol_layer {
            bindings = <
        // 第一排：数字 1-0
            &kp N1         &kp N2         &kp N3        &kp N4         &kp N5            &kp N6         &kp N7          &kp N8          &kp N9        &kp N0
        // 第二排：左修饰键 + 右修饰键
            &none          &kp LGUI       &kp LSHFT     &kp LCTRL      &kp LALT          &kp RALT       &kp RCTRL       &kp RSHFT       &kp RGUI      &none
        // 第三排：反引号、减号、等号、Caps Lock、单引号、左方括号、右方括号、反斜杠
            &none          &kp GRAVE      &kp MINUS     &kp EQUAL      &kp CAPS          &kp SQT        &kp LBKT        &kp RBKT        &kp BSLH      &none
        // 底行：旋钮按下保持透传，其余保持透传
                        &trans        &trans         &trans        &trans          &trans            &trans        &trans          &trans
            >;
            sensor-bindings = <SYMBOL_LEFT_ENCODER BASE_RIGHT_ENCODER>;
        };

        // 第 4 层：Fn 层
        // - 左手放 F1-F12
        // - 右手补一组右修饰键
        // - 旋钮旋转显式保持第 0 层行为，按下继续走按键透传
        function_layer {
            bindings = <
        // 第一排：F1-F4
            &kp F1         &kp F2         &kp F3        &kp F4         &none             &none          &none           &none           &none         &none
        // 第二排：F5-F8 + 右修饰键
            &kp F5         &kp F6         &kp F7        &kp F8         &none             &kp RALT       &kp RCTRL       &kp RSHFT       &kp RGUI      &none
        // 第三排：F9-F12
            &kp F9         &kp F10        &kp F11       &kp F12        &none             &none          &none           &none           &none         &none
        // 底行：旋钮按下保持透传，其余透传
                        &trans        &trans         &trans        &trans          &trans            &trans        &trans          &trans
            >;
            sensor-bindings = <BASE_LEFT_ENCODER BASE_RIGHT_ENCODER>;
        };

        // 第 5 层：设备控制层
        // - 通过第 2 层 + 第 3 层同时按住进入
        // - 左手切换蓝牙 1-5
        // - 右手调小红点灵敏度、清空当前蓝牙 profile 配对
        // - 旋钮旋转显式保持第 0 层行为，按下继续走按键透传
        device_layer {
            bindings = <
        // 第一排：留空，避免误触
            &none          &none          &none         &none          &none             &none          &none           &none           &none         &none
        // 第二排：蓝牙 profile + 设备控制
            &bt BT_SEL 0   &bt BT_SEL 1   &bt BT_SEL 2  &bt BT_SEL 3   &bt BT_SEL 4      &none          U_MSS_TP_S_D   &bt BT_CLR      U_MSS_TP_S_I &none
        // 第三排：留空，避免误触
            &none          &none          &none         &none          &none             &none          &none           &none           &none         &none
        // 底行：旋钮按下保持透传，其余透传
                        &trans        &trans         &trans        &trans          &trans            &trans        &trans          &trans
            >;
            sensor-bindings = <BASE_LEFT_ENCODER BASE_RIGHT_ENCODER>;
        };
    };
};
