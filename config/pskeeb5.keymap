#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/mouse.h>
#include <dt-bindings/zmk/bt.h>
#include <behaviors/mouse_setting.dtsi>
#include <dt-bindings/zmk/mouse_settings.h>

// 小红点灵敏度
#define U_MSS_TP_S_I &mms MS_TP_SENSITIVITY_INCR
#define U_MSS_TP_S_D &mms MS_TP_SENSITIVITY_DECR

#define ENCODER_SCROLL_STEP 2000

// 默认层旋钮：左音量，右滚动
#define BASE_LEFT_ENCODER &inc_dec_kp C_VOL_DN C_VOL_UP
#define BASE_RIGHT_ENCODER &inc_dec_msc MOVE_Y(-ENCODER_SCROLL_STEP) MOVE_Y(ENCODER_SCROLL_STEP)

// 导航层右旋钮：方向
#define NAV_RIGHT_ENCODER &inc_dec_kp LEFT RIGHT

// 鼠标层左旋钮：亮度
#define SYMBOL_LEFT_ENCODER &inc_dec_kp C_BRI_DN C_BRI_UP

/ {
    behaviors {
        // 点按出键，长按出修饰键
        ht: hold_tap {
            display-name = "Hold Tap";
            label = "hold_tap";
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "balanced";
            tapping-term-ms = <220>;
            quick-tap-ms = <200>;
            bindings = <&kp>, <&kp>;
        };

        // 点按出键，长按切层
        lt: layer_tap {
            display-name = "Layer Tap";
            compatible = "zmk,behavior-hold-tap";
            label = "LAYER_TAP";
            #binding-cells = <2>;
            tapping-term-ms = <200>;
            quick-tap-ms = <200>;
            bindings = <&mo>, <&kp>;
        };

        // 编码器滚轮模板
        inc_dec_msc: sensor_rotate_msc {
            compatible = "zmk,behavior-sensor-rotate-var";
            #sensor-binding-cells = <2>;
            bindings = <&msc>, <&msc>;
            tap-ms = <20>;
        };
    };

    combos {
        compatible = "zmk,combos";

        // S + X -> `
        combo_grave {
            timeout-ms = <50>;
            layers = <0>;
            key-positions = <11 21>;
            bindings = <&kp GRAVE>;
        };

        // D + C -> -
        combo_minus {
            timeout-ms = <50>;
            layers = <0>;
            key-positions = <12 22>;
            bindings = <&kp MINUS>;
        };

        // F + V -> =
        combo_equal {
            timeout-ms = <50>;
            layers = <0>;
            key-positions = <13 23>;
            bindings = <&kp EQUAL>;
        };

        // H + N -> '
        combo_quote {
            timeout-ms = <50>;
            layers = <0>;
            key-positions = <15 25>;
            bindings = <&kp SQT>;
        };

        // J + M -> [
        combo_left_bracket {
            timeout-ms = <50>;
            layers = <0>;
            key-positions = <16 26>;
            bindings = <&kp LBKT>;
        };

        // K + , -> ]
        combo_right_bracket {
            timeout-ms = <50>;
            layers = <0>;
            key-positions = <17 27>;
            bindings = <&kp RBKT>;
        };

        // L + . -> backslash
        combo_backslash {
            timeout-ms = <50>;
            layers = <0>;
            key-positions = <18 28>;
            bindings = <&kp BSLH>;
        };

        // F + J -> F20
        combo_f20 {
            timeout-ms = <50>;
            layers = <0>;
            key-positions = <13 16>;
            bindings = <&kp F20>;
        };

        // D + K -> Ctrl + Space
        combo_ctrl_space {
            timeout-ms = <50>;
            layers = <0>;
            key-positions = <12 17>;
            bindings = <&kp LC(SPACE)>;
        };

        // S + L -> Gui + Space
        combo_gui_space {
            timeout-ms = <50>;
            layers = <0>;
            key-positions = <11 18>;
            bindings = <&kp LG(SPACE)>;
        };

        // MB1 + MB2 -> MB3
        combo_mouse_middle_click {
            timeout-ms = <50>;
            layers = <3>;
            key-positions = <5 6>;
            bindings = <&mkp MCLK>;
        };
    };

    conditional_layers {
        compatible = "zmk,conditional-layers";

        // 2 + 3 -> 5
        device_layer {
            if-layers = <2 3>;
            then-layer = <5>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        // 默认层：QWERTY + homerow mods；Esc/Space/Enter/Del 长按切 1/2/3/4；左旋钮静音，右旋钮截图
        default_layer {
            bindings = <
                &kp Q          &kp W          &ht LALT E      &kp R           &kp T              &kp Y          &kp U            &ht LALT I      &kp O          &kp P
                &kp A          &ht LGUI S     &ht LSHFT D     &ht LCTRL F     &kp G              &kp H          &ht LCTRL J      &ht LSHFT K     &ht LGUI L     &kp SEMI
                &kp Z          &kp X          &kp C           &kp V           &kp B              &kp N          &kp M            &kp COMMA       &kp DOT        &kp FSLH
                                &kp C_MUTE    &lt 1 ESC        &lt 2 SPACE      &kp TAB            &kp BSPC       &lt 3 ENTER       &lt 4 DEL        &kp PSCRN
            >;
            sensor-bindings = <BASE_LEFT_ENCODER BASE_RIGHT_ENCODER>;
        };

        // 小数字键盘：右手数字区，左手补修饰键；旋钮保持默认
        numpad_layer {
            bindings = <
                &none          &none          &kp LALT        &none           &none             &kp KP_PLUS    &kp N7           &kp N8          &kp N9         &kp KP_MULTIPLY
                &none          &kp LGUI       &kp LSHFT       &kp LCTRL       &none             &kp KP_MINUS   &kp N4           &kp N5          &kp N6         &kp KP_DIVIDE
                &none          &none          &none           &none           &none             &kp N0         &kp N1           &kp N2          &kp N3         &kp KP_DOT
                                &trans         &trans          &trans          &trans            &trans         &trans           &trans          &trans
            >;
            sensor-bindings = <BASE_LEFT_ENCODER BASE_RIGHT_ENCODER>;
        };

        // 导航层：PgUp/PgDn/Home/End + 方向键；右旋钮改为左右方向键
        navigation_layer {
            bindings = <
                &none          &none          &kp LALT        &none           &none             &kp PG_UP      &none            &kp UP          &none          &kp HOME
                &none          &kp LGUI       &kp LSHFT       &kp LCTRL       &none             &none          &kp LEFT         &kp DOWN        &kp RIGHT      &none
                &none          &none          &none           &none           &none             &kp PG_DN      &none            &none           &none          &kp END
                                &trans         &trans          &trans          &trans            &trans         &trans           &trans          &trans
            >;
            sensor-bindings = <BASE_LEFT_ENCODER NAV_RIGHT_ENCODER>;
        };

        // 鼠标层：左手滚动/移动，右手鼠标键/修饰键；左旋钮调亮度
        number_symbol_layer {
            bindings = <
                &msc SCRL_LEFT &none          &mmv MOVE_UP     &none           &msc SCRL_UP      &mkp MB1       &mkp MB2         &kp LALT        &mkp MB4       &mkp MB5
                &none          &mmv MOVE_LEFT &mmv MOVE_DOWN   &mmv MOVE_RIGHT &none             &none          &kp LCTRL        &kp LSHFT       &kp LGUI       &none
                &msc SCRL_RIGHT &none         &none            &none           &msc SCRL_DOWN    &none          &none            &none           &none          &none
                                &trans         &trans          &trans          &trans            &trans         &trans           &trans          &trans
            >;
            sensor-bindings = <SYMBOL_LEFT_ENCODER BASE_RIGHT_ENCODER>;
        };

        // Fn 层：左手 F1-F12，右手修饰键；旋钮保持默认
        function_layer {
            bindings = <
                &kp F1         &kp F2         &kp F3          &kp F4          &none             &none          &none            &kp LALT        &none          &none
                &kp F5         &kp F6         &kp F7          &kp F8          &none             &none          &kp LCTRL        &kp LSHFT       &kp LGUI       &none
                &kp F9         &kp F10        &kp F11         &kp F12         &none             &none          &none            &none           &none          &none
                                &trans         &trans          &trans          &trans            &trans         &trans           &trans          &trans
            >;
            sensor-bindings = <BASE_LEFT_ENCODER BASE_RIGHT_ENCODER>;
        };

        // 设备层：2+3 同时激活；切蓝牙、调小红点灵敏度、清配对
        device_layer {
            bindings = <
                &none          &none          &none           &none           &none             &none          &none            &none           &none          &none
                &bt BT_SEL 0   &bt BT_SEL 1   &bt BT_SEL 2    &bt BT_SEL 3    &bt BT_SEL 4      &none          U_MSS_TP_S_D    &bt BT_CLR      U_MSS_TP_S_I  &none
                &none          &none          &none           &none           &none             &none          &none            &none           &none          &none
                                &trans         &trans          &trans          &trans            &trans         &trans           &trans          &trans
            >;
            sensor-bindings = <BASE_LEFT_ENCODER BASE_RIGHT_ENCODER>;
        };
    };
};
